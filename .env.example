# Cloakroom configuration (all optional; sensible defaults run with zero setup).
# Which adapter each pluggable layer uses -- the single swap point for cloud portability.
CLOAKROOM_DETECTOR=regex          # regex | presidio | comprehend (AWS)
CLOAKROOM_VAULT=memory            # memory | redis | dynamodb (AWS)
CLOAKROOM_LLM=mock                # mock | ollama | bedrock (AWS)

# Masking strategy -- HOW a detected value is replaced (per-request override: "strategy" field).
#   token             [PFI_ACCOUNT_1]   reversible   default; LLM round-trip
#   redact            ••••••• •••••     one-way      drop the value
#   format_preserving 918273645501      reversible   keep shape/length (valid-looking)
#   prefix            P••••••           one-way      keep leading chars -> stays sortable
CLOAKROOM_MASK_STRATEGY=token
CLOAKROOM_PREFIX_KEEP=1            # chars kept by the prefix (sortable) strategy

# Vault: base64 Fernet key (generated in-memory if unset) and mapping TTL in seconds.
CLOAKROOM_ENCRYPTION_KEY=
CLOAKROOM_VAULT_TTL=3600

# Redis vault adapter
CLOAKROOM_REDIS_URL=redis://localhost:6379/0

# Ollama local LLM adapter (free, runs on-device)
CLOAKROOM_OLLAMA_URL=http://localhost:11434
CLOAKROOM_OLLAMA_MODEL=llama3.2

# Presidio (free NER) spaCy model
CLOAKROOM_SPACY_MODEL=en_core_web_sm

# --- AWS adapters (install with: pip install -e ".[aws]") ---
# Uses standard AWS credential discovery (env vars, ~/.aws/credentials, or IAM role).
CLOAKROOM_AWS_REGION=us-east-1
CLOAKROOM_COMPREHEND_LANG=en
CLOAKROOM_DYNAMO_TABLE=cloakroom-vault
CLOAKROOM_BEDROCK_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0

# CORS for the browser playground (comma-separated origins, or * for any)
CLOAKROOM_CORS_ORIGINS=*
